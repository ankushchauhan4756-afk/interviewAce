# Root environment variables for Render and local setup

# Backend
MONGODB_URI=mongodb://<username>:<password>@host:port/interviewace
JWT_SECRET=your_jwt_secret_here
NODE_ENV=production
FRONTEND_URL=https://your-frontend-service.onrender.com

# Render will provide PORT automatically for backend
PORT=5000

# Frontend
VITE_API_BASE_URL=https://your-backend-service.onrender.com/api
